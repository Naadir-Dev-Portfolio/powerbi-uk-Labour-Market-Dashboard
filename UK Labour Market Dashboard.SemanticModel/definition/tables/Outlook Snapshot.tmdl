table 'Outlook Snapshot'
	lineageTag: bf69eb02-6c40-49e9-93cf-6857cb21bac5

	measure 'Outlook Direction' = SELECTEDVALUE('Outlook Snapshot'[Direction])
		displayFolder: Summary
		lineageTag: 304d11f1-eea6-4c77-89b5-898bf29b935b

	measure 'Outlook Headline' = SELECTEDVALUE('Outlook Snapshot'[Headline])
		displayFolder: Summary
		lineageTag: 02f97efa-08e3-42a9-89ed-92ad1d9318d1

	measure 'Outlook Detail' = SELECTEDVALUE('Outlook Snapshot'[Detail])
		displayFolder: Summary
		lineageTag: eed79f74-ccb9-4c5a-9dff-6df04593645d

	measure 'Latest Common Signal Date' = MAX('Outlook Snapshot'[SnapshotDate])
		formatString: mmmm yyyy
		displayFolder: Summary
		lineageTag: c62f2f6a-c00b-456f-8d15-81818b1de62b

	measure 'Latest Claimant Count (K)' = MAX('Outlook Snapshot'[NationalClaimantCountK])
		formatString: #,##0.0

table 'Fact Local Claimant'
	lineageTag: 0606240b-724e-4722-87f8-0539687fc07b

	measure 'Local Claimant Count' = SUM('Fact Local Claimant'[PeopleCount])
		formatString: #,##0
		displayFolder: Local Metrics
		lineageTag: 9f39e25c-d529-4f7a-bc02-d3cc44799a4a

	measure 'Local Claimant Rate %' = AVERAGE('Fact Local Claimant'[PeopleRatePct]) / 100
		formatString: 0.0%
		displayFolder: Local Metrics
		lineageTag: e9d11d10-ad28-4ae5-97d5-744f3e57efa7

	measure 'Local Claimant YoY Change' = SUM('Fact Local Claimant'[PeopleYoYChange])

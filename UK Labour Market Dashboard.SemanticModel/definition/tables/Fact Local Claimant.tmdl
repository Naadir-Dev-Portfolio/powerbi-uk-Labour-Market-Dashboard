	partition 'Fact Local Claimant-Partition' = m
		mode: import
		source =
				let
				    Source = Csv.Document(File.Contents(SourceDataFolder & "fact_local_claimant_latest.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
				    #"Promoted Headers" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
				    #"Changed Type" = Table.TransformColumnTypes(#"Promoted Headers",{
				        {"SnapshotDate", type date},
				        {"AreaName", type text},
				        {"AreaCode", type text},
				        {"AreaLevel", type text},
				        {"IsLocalArea", type logical},
				        {"MenCount", type number},
				        {"WomenCount", type number},
				        {"PeopleCount", type number},
				        {"MenRatePct", type number},
				        {"WomenRatePct", type number},
				        {"PeopleRatePct", type number},
				        {"MenYoYChange", type number},
				        {"WomenYoYChange", type number},
				        {"PeopleYoYChange", type number},
				        {"MenRateYoYChange", type number}
				    })
				in
				    #"Changed Type"

